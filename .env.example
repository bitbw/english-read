# Auth.js
AUTH_SECRET=                        # 运行 npx auth secret 生成
AUTH_URL=http://localhost:3000

# Google OAuth（Google Cloud Console 获取）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth（GitHub Developer Settings 获取）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Vercel Postgres（Neon）- Vercel Storage 自动注入，本地需手动填
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Vercel Blob - Vercel Storage 自动注入，本地需手动填
BLOB_READ_WRITE_TOKEN=

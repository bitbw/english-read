# Auth.js
AUTH_SECRET=                        # 运行 npx auth secret 生成
AUTH_URL=http://localhost:3000

# Google OAuth（Google Cloud Console 获取）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth（GitHub Developer Settings 获取）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Vercel Postgres（Neon）- Vercel Storage 自动注入，本地需手动填
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Vercel Blob - Vercel Storage 自动注入，本地需手动填
BLOB_READ_WRITE_TOKEN=

# Vercel AI Gateway（短语复习干扰项：GET /api/review/similar-words 多词分支）
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# Google Cloud Translation API v2（/api/dictionary 回退机翻）
GOOGLE_TRANSLATE_API_KEY=

# PostHog（客户端埋点；Project settings → Project API key / Host）
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# 阿里云融合认证 - 短信验证码（号码认证控制台「赠送签名 + 赠送模板」）
# 文档见 docs/阿里云/。RAM 需 dypns:SendSmsVerifyCode、CheckSmsVerifyCode
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# 控制台的签名名称、模板 CODE；模板变量与 ALIYUN_SMS_TEMPLATE_PARAM 一致（按控制台实际变量名）
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
# 默认可不填，需与已审核短信模板中变量一致，例如: {"code":"##code##","min":"5"}
# ALIYUN_SMS_TEMPLATE_PARAM=
# 非「默认方案」时填写
# ALIYUN_SMS_SCHEME_NAME=
